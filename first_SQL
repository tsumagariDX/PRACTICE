import sqlite3

def connect_db(db_path):
    conn = sqlite3.connect(db_path)
    return conn
    
def create_table(conn):
    cursor = conn.cursor()
    cursor.execute("""
    CREATE TABLE IF NOT EXISTS stocks(
        name TEXT,
        stock INTEGER
    )
    """)
    conn.commit()

def insert_stock(conn, name, stock):
    cursor = conn.cursor()
    cursor.execute(
        "INSERT INTO stocks (name, stock) VALUES (?, ?)",
        (name, stock)
    )
    conn.commit()

def get_all_stocks(conn):
    cursor = conn.cursor()
    cursor.execute("SELECT name, stock FROM stocks")
    rows = cursor.fetchall()
    return rows

def show_all_stocks(rows):
    if not rows:
        print("データがありません")
    else:
        for name, stock in rows:
            print(f"{name}:{stock}")

def find_stock_by_name(conn, name):
    cursor = conn.cursor()
    cursor.execute("SELECT name, stock FROM stocks WHERE name = ?", (name,))
    found_stock = cursor.fetchone()
    return found_stock

