from pathlib import Path

def count_extensions(files):
    ext_count = {}
    for file in files:
        ext = file.suffix.lower()
        if ext == "":
            ext = "拡張子なし"
        
        if ext not in ext_count:
            ext_count[ext] = 0
        ext_count[ext] += 1
        
    return ext_count

def sort_extensions(ext_count):
    sorted_data = sorted(ext_count.items(), key=lambda x: x[1], reverse=True)
    return sorted_data

def get_files(folder_path):
    files = []
    folder = Path(folder_path)
    for p in folder.iterdir():
        if p.is_file():
            files.append(p)
    return files

def group_files_by_extension(files):
    group_files = {}
    for file in files:
        ext = file.suffix.lower()
        if ext == "":
            ext = "拡張子なし"

        if ext not in group_files:
            group_files[ext] = []

        group_files[ext].append(file.name)
    return group_files

def show_report(sorted_data):
    print("拡張子ごとの件数:")
    for ext, count in sorted_data:
        print(f"{ext}: {count}")

def show_group_report(group_files,sorted_data):
    for ext, count in sorted_data:
        print(f"{ext}: {count}")
        for name in group_files[ext]:
            print(f" - {name}")

def organize_files(files, folder_path):
    folder = Path(folder_path)
    for file in files:
        ext = file.suffix.lower()
        if ext == "":
            folder_name = "no_extension"
        else:
            folder_name = ext[1:]
        target_folder = folder / folder_name
        target_folder.mkdir(exist_ok=True)
        dest_path = target_folder / file.name
        file.rename(dest_path)

def main():
    folder_path = "input_files"
    files = get_files(folder_path)
    organize_files(files, folder_path)
    print("整理が完了しました")

if __name__ == "__main__":
    main()
